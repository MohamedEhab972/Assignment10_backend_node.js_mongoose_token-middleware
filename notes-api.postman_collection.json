{
  "info": {
    "name": "Notes App API",
    "_postman_id": "notes-app-collection",
    "description": "Notes and Users API collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "noteId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Sign Up",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Mohamed Ehab\",\n  \"email\": \"mohamed@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"01012345678\",\n  \"age\": 25\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/signup",
              "host": ["{{baseUrl}}"],
              "path": ["users", "signup"]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.collectionVariables.set('token', res.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"mohamed@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/login",
              "host": ["{{baseUrl}}"],
              "path": ["users", "login"]
            }
          }
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "authorization",
                "value": "{{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": ["{{baseUrl}}"],
              "path": ["users"]
            }
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "authorization",
                "value": "{{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Mohamed Updated\",\n  \"phone\": \"01098765432\",\n  \"age\": 26\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/update",
              "host": ["{{baseUrl}}"],
              "path": ["users", "update"]
            }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "authorization",
                "value": "{{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/delete",
              "host": ["{{baseUrl}}"],
              "path": ["users", "delete"]
            }
          }
        }
      ]
    },
    {
      "name": "Notes",
      "item": [
        {
          "name": "Create Note",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data._id) {",
                  "  pm.collectionVariables.set('noteId', res.data._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "authorization",
                "value": "{{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My First Note\",\n  \"content\": \"This is the content of my first note\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/notes",
              "host": ["{{baseUrl}}"],
              "path": ["notes"]
            }
          }
        },
        {
          "name": "Get Note By ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "authorization",
                "value": "{{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/notes/{{noteId}}",
              "host": ["{{baseUrl}}"],
              "path": ["notes", "{{noteId}}"]
            }
          }
        },
        {
          "name": "Get Notes Paginated and Sorted",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "authorization",
                "value": "{{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/notes/paginate-sort?page=1&limit=3",
              "host": ["{{baseUrl}}"],
              "path": ["notes", "paginate-sort"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "3" }
              ]
            }
          }
        },
        {
          "name": "Get Note By Content",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "authorization",
                "value": "{{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/notes/note-by-content?content=Workout Plan",
              "host": ["{{baseUrl}}"],
              "path": ["notes", "note-by-content"],
              "query": [
                { "key": "content", "value": "Workout Plan" }
              ]
            }
          }
        },
        {
          "name": "Get Notes With User Info",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "authorization",
                "value": "{{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/notes/note-with-user",
              "host": ["{{baseUrl}}"],
              "path": ["notes", "note-with-user"]
            }
          }
        },
        {
          "name": "Get Notes With Aggregation",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "authorization",
                "value": "{{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/notes/aggregate?title=Code Review Notes",
              "host": ["{{baseUrl}}"],
              "path": ["notes", "aggregate"],
              "query": [
                { "key": "title", "value": "Code Review Notes" }
              ]
            }
          }
        },
        {
          "name": "Update Note (Partial)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "authorization",
                "value": "{{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Title\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/notes/{{noteId}}",
              "host": ["{{baseUrl}}"],
              "path": ["notes", "{{noteId}}"]
            }
          }
        },
        {
          "name": "Update All Notes Titles",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "authorization",
                "value": "{{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"New Title For All\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/notes/all",
              "host": ["{{baseUrl}}"],
              "path": ["notes", "all"]
            }
          }
        },
        {
          "name": "Replace Entire Note (PUT)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "authorization",
                "value": "{{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Completely New Title\",\n  \"content\": \"Completely new content replacing the old one\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/notes/{{noteId}}",
              "host": ["{{baseUrl}}"],
              "path": ["notes", "{{noteId}}"]
            }
          }
        },
        {
          "name": "Delete Note",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "authorization",
                "value": "{{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/notes/{{noteId}}",
              "host": ["{{baseUrl}}"],
              "path": ["notes", "{{noteId}}"]
            }
          }
        },
        {
          "name": "Delete All Notes",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "authorization",
                "value": "{{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/notes",
              "host": ["{{baseUrl}}"],
              "path": ["notes"]
            }
          }
        }
      ]
    }
  ]
}
